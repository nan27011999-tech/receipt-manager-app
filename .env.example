# ReceiptFlow LINE Bot - Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# cp .env.example .env

# ===== LINE Messaging API =====
# ดูได้จาก LINE Developers Console: https://developers.line.biz/
# 1. สร้าง Provider และ Channel (Messaging API)
# 2. เข้า Basic settings -> Channel secret
# 3. เข้า Messaging API -> Channel access token

LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# ===== Server Config =====
PORT=3000
NODE_ENV=development

# ===== OpenAI API (สำหรับ OCR อ่านใบเสร็จ) =====
# ดูได้จาก: https://platform.openai.com/api-keys
# ใช้ GPT-4o Vision เพื่ออ่านรูปใบเสร็จ
OPENAI_API_KEY=sk-your_openai_key_here

# ===== Google Cloud Vision (ทางเลือก OCR) =====
# ดูได้จาก: https://console.cloud.google.com/
GOOGLE_CLOUD_KEY_FILE=./google-credentials.json
GOOGLE_CLOUD_PROJECT_ID=your_project_id

# ===== Database (เลือกใช้อย่างใดอย่างหนึ่ง) =====
# MongoDB Atlas (แนะนำสำหรับเริ่มต้น - ฟรี 512MB)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/receiptflow

# PostgreSQL (สำหรับ production)
# DATABASE_URL=postgresql://user:password@localhost:5432/receiptflow

# ===== Google Sheets (สำหรับ sync ข้อมูล) =====
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=your_private_key_here

# ===== LIFF (LINE Front-end Framework) =====
# สร้าง LIFF App ใน LINE Developers Console
LIFF_ID=your_liff_id_here

# ===== Webhook URL (ngrok สำหรับ development) =====
# รันคำสั่ง: npx ngrok http 3000
# แล้วนำ URL ที่ได้ไปใส่ใน LINE Developers Console -> Webhook URL
WEBHOOK_URL=https://your-ngrok-url.ngrok.io/webhook
